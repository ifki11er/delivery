generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  CUSTOMER
  OWNER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  WITHDRAWN
}

enum StoreStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phoneNumber   String?   @unique
  role          Role      @default(CUSTOMER)
  status        UserStatus @default(ACTIVE)
  accounts      Account[]
  sessions      Session[]
  applications  BusinessApplication[]
  stores        Store[]
  employments   Employee[]
  blacklists    Blacklist[]
  deletedAt     DateTime? // 소프트 삭제용 필드
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Store {
  id                 String     @id @default(cuid())
  ownerId            String
  owner              User       @relation(fields: [ownerId], references: [id])
  name               String
  address            String?
  contact            String?
  representativeName String?
  businessRegNo      String?
  wifiIpAddress      String?
  currency           String     @default("원")
  status             StoreStatus @default(ACTIVE)
  employees          Employee[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model Employee {
  id            String       @id @default(cuid())
  storeId       String
  store         Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  role          String       @default("STAFF") // STAFF, MANAGER
  wageType      String       @default("HOURLY") // HOURLY, DAILY
  wageAmount    Int          @default(0)
  workStartTime String       @default("09:00")
  workEndTime   String       @default("18:00")
  status        String       @default("ACTIVE") // ACTIVE, INACTIVE
  histories     EmploymentHistory[]
  attendances   Attendance[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([storeId, userId])
}

enum AttendanceStatus {
  NORMAL
  LATE
  EARLY_LEAVE
  ABSENT
}

model Attendance {
  id           String    @id @default(cuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         String    // YYYY-MM-DD
  checkInTime  DateTime?
  checkOutTime DateTime?
  workMinutes  Int       @default(0)
  status       AttendanceStatus @default(NORMAL)
  
  // 급여 스냅샷 필드
  wageType     String    @default("HOURLY") // HOURLY, DAILY, MONTHLY
  wageAmount   Int       @default(0)
  calculatedWage Int?    // 당일 정산된 최종 급여 (월급은 null)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([employeeId, date])
}

model BusinessApplication {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName       String
  address            String?
  contact            String?
  representativeName String?
  businessRegNo      String    // 사업자등록번호
  imageUrl           String?   // 사업자등록증 이미지 주소
  status             String    @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Blacklist {
  id          String   @id @default(cuid())
  phoneNumber String   @unique
  reason      String   @db.Text
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmploymentHistory {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())
  resignedAt  DateTime?
}
