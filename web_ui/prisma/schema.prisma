generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  CUSTOMER
  OWNER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  WITHDRAWN
}

enum StoreStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phoneNumber   String?   @unique
  role          Role      @default(CUSTOMER)
  status        UserStatus @default(ACTIVE)
  accounts      Account[]
  sessions      Session[]
  applications  BusinessApplication[]
  stores        Store[]
  employments   Employee[]
  blacklists    Blacklist[]
  printJobs     PrintJob[]
  deletedAt     DateTime? // 소프트 삭제용 필드
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Store {
  id                 String     @id @default(cuid())
  ownerId            String
  owner              User       @relation(fields: [ownerId], references: [id])
  name               String
  address            String?
  contact            String?
  representativeName String?
  businessRegNo      String?
  wifiIpAddress      String?
  currency           String     @default("₫")
  timeZone           String     @default("UTC")
  status             StoreStatus @default(ACTIVE)
  employees          Employee[]
  posTables          PosTable[]
  posCategories      PosCategory[]
  posMenus           PosMenu[]
  posOrders          PosOrder[]
  printJobs          PrintJob[]
  dailySequences     StoreDailySequence[]
  menuLanguageEnabled Boolean   @default(false) @map("menu_language_enabled")
  menuLanguageRules   StoreMenuLanguageRule[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model Employee {
  id            String       @id @default(cuid())
  storeId       String
  store         Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  wageType      String       @default("HOURLY") // HOURLY, DAILY
  wageAmount    Int          @default(0)
  managementMode String      @default("FULL") @map("management_mode")
  workStartTime String       @default("09:00")
  workEndTime   String       @default("18:00")
  status        String       @default("ACTIVE") // ACTIVE, INACTIVE
  histories     EmploymentHistory[]
  attendances   Attendance[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([storeId, userId])
}

enum AttendanceStatus {
  NORMAL
  LATE
  EARLY_LEAVE
  ABSENT
}

model Attendance {
  id           String    @id @default(cuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         String    // YYYY-MM-DD
  checkInTime  DateTime?
  checkOutTime DateTime?
  workMinutes  Int       @default(0)
  status       AttendanceStatus @default(NORMAL)
  
  // 급여 스냅샷 필드
  wageType     String    @default("HOURLY") // HOURLY, DAILY, MONTHLY
  wageAmount   Int       @default(0)
  calculatedWage Int?    // 당일 정산된 최종 급여 (월급은 null)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([employeeId, date])
}

model BusinessApplication {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName       String
  address            String?
  contact            String?
  representativeName String?
  businessRegNo      String    // 사업자등록번호
  imageUrl           String?   // 사업자등록증 이미지 주소
  status             String    @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Blacklist {
  id          String   @id @default(cuid())
  phoneNumber String
  reason      String   @db.Text
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([phoneNumber, reporterId])
}

model EmploymentHistory {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())
  resignedAt  DateTime?
}

model PosTable {
  id        String     @id
  storeId   String     @map("store_id")
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  status    String     @default("EMPTY")
  sortOrder Int        @default(0) @map("sort_order")
  orders    PosOrder[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([storeId])
  @@map("pos_tables")
}

model PosCategory {
  id        String    @id
  storeId   String    @map("store_id")
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int       @default(0) @map("sort_order")
  menus     PosMenu[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([storeId])
  @@map("pos_categories")
}

model PosMenu {
  id         String         @id
  storeId    String         @map("store_id")
  store      Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId String         @map("category_id")
  category   PosCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  menuCode   String         @default("") @map("menu_code")
  name       String
  price      Int            @default(0)
  isActive   Boolean        @default(true) @map("is_active")
  orderItems PosOrderItem[]
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  @@index([storeId])
  @@map("pos_menus")
}

model PosOrder {
  id            String         @id
  storeId       String         @map("store_id")
  store         Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  tableId       String         @map("table_id")
  table         PosTable       @relation(fields: [tableId], references: [id], onDelete: Cascade)
  status        String         @default("OPEN")
  note          String?
  paymentMethod String?        @map("payment_method")
  total         Int            @default(0)
  items         PosOrderItem[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  closedAt      DateTime?      @map("closed_at")

  @@index([storeId, status])
  @@map("pos_orders")
}

model PosOrderItem {
  id        String    @id
  orderId   String    @map("order_id")
  order     PosOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuId    String?   @map("menu_id")
  menu      PosMenu?  @relation(fields: [menuId], references: [id], onDelete: SetNull)
  name      String
  menuCode  String    @default("") @map("menu_code")
  price     Int       @default(0)
  quantity  Int       @default(1)
  itemType  String    @default("MENU") @map("item_type")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([orderId])
  @@map("pos_order_items")
}

model PrintJob {
  id         String   @id @default(cuid())
  storeId    String   @map("store_id")
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  source     String   @default("DELIVERY_SHARE")
  status     String   @default("PRINTED")
  rawText    String   @map("raw_text") @db.Text
  parsedData String?  @map("parsed_data") @db.Text
  phone      String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([storeId, createdAt])
  @@index([userId, createdAt])
  @@map("print_jobs")
}

model StoreDailySequence {
  id           String   @id @default(cuid())
  storeId      String   @map("store_id")
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  businessDate String   @map("business_date")
  sequence     Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([storeId, businessDate])
  @@map("store_daily_sequences")
}

model StoreMenuLanguageRule {
  id              String   @id @default(cuid())
  storeId          String   @map("store_id")
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  matchText        String   @map("match_text")
  replacementText  String   @map("replacement_text")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([storeId, matchText])
  @@index([storeId])
  @@map("store_menu_language_rules")
}

model AuditLog {
  id         String   @id
  actorId    String?  @map("actor_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([action, createdAt])
  @@map("audit_logs")
}

model RateLimitBucket {
  key       String   @id
  count     Int
  resetAt   DateTime @map("reset_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([resetAt])
  @@map("rate_limit_buckets")
}
